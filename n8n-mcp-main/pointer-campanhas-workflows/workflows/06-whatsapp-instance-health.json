{
  "name": "Pointer - 06 WhatsApp Instance Health",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ]
        }
      },
      "id": "daily-maintenance",
      "name": "Daily Maintenance",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-720, 0]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "update public.whatsapp_instances\nset sent_today = 0,\n    sent_today_date = current_date,\n    updated_at = now()\nwhere sent_today_date is distinct from current_date\nreturning id, name, sent_today_date;"
      },
      "id": "reset-daily-counters",
      "name": "Reset Daily Counters",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [-460, 0],
      "credentials": {
        "postgres": {
          "id": "__N8N_POSTGRES_CREDENTIAL_ID__",
          "name": "__N8N_POSTGRES_CREDENTIAL_NAME__"
        }
      }
    }
  ],
  "connections": {
    "Daily Maintenance": { "main": [[{ "node": "Reset Daily Counters", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "saveExecutionProgress": true },
  "active": false
}
